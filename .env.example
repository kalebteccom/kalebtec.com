# MongoDB Atlas connection string
DATABASE_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/kalebtec?retryWrites=true&w=majority

# Payload CMS secret (generate a strong random string for production)
PAYLOAD_SECRET=change-me-in-production

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare R2 storage (for media uploads)
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=kalebtec-media
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
